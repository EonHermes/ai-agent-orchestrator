# AI Agent Orchestrator Configuration
# Copy this file to .env and fill in the values

# Required: OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override defaults
ORCHESTRATOR_SERVER_PORT=8081
ORCHESTRATOR_LLM_OPENROUTER_MODEL=anthropic/claude-3-opus
ORCHESTRATOR_LOGGING_LEVEL=info
ORCHESTRATOR_DATABASE_URL=sqlite:/data/orchestrator.db
